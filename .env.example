# Secrets only — API keys, service credentials, etc.
# Public config (names, dates, venue) lives in lib/config.ts

# Example: email service for RSVP notifications
# RESEND_API_KEY=re_...

# ── Supabase (server-only — never prefix with NEXT_PUBLIC_) ──────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Admin auth ───────────────────────────────────────────────────────────────
# Generate the password hash: node scripts/hash-password.mjs yourpassword
ADMIN_PASSWORD_HASH=scrypt:salt:hash

# Sign admin session cookies — 32 random bytes as hex:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=your-32-byte-random-hex-secret
